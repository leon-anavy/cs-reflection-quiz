    "uuid": "11.1.0"
  },
  "devDependencies": {
    "jest": "29.7.0",
    "mongodb-memory-server": "10.1.2",
    "nodemon": "3.1.9",
    "supertest": "7.1.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.js"],
    "globalSetup": "./tests/globalSetup.js",
    "globalTeardown": "./tests/globalTeardown.js"
